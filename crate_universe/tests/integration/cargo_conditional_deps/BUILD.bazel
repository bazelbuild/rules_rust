load("@crate_index_cargo_conditional_deps//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

rust_library(
    name = "conditional_deps",
    srcs = [
        "src/lib.rs",
    ],
    aliases = aliases(),
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
    ),
    deps = all_crate_deps(
        normal = True,
    ),
)

rust_binary(
    name = "example",
    srcs = [
        "src/main.rs",
    ],
    deps = [":conditional_deps"],
)

rust_test(
    name = "unit_test",
    crate = ":conditional_deps",
)
