load("//rust/private:rust.bzl", "rust_binary", "rust_library", "rust_test")

package(default_visibility = ["//visibility:private"])

rust_library(
    name = "lib",
    srcs = ["lib.rs"],
    crate_name = "rust_test_sharding_lib",
    edition = "2018",
    deps = [
        "//rust/runfiles",
    ],
)

rust_binary(
    name = "launcher",
    srcs = ["main.rs"],
    edition = "2018",
    visibility = ["//rust/private:__pkg__"],
    deps = [
        ":lib",
    ],
)

rust_test(
    name = "launcher_test",
    crate = ":lib",
    edition = "2018",
    env = {
        # The launcher unit tests mutate process environment variables to cover
        # Bazel test protocol behavior, so keep libtest single-threaded here.
        "RUST_TEST_THREADS": "1",
    },
)
