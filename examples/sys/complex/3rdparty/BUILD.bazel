load("@rules_rust//crate_universe:defs.bzl", "crate", "crates_vendor")

crates_vendor(
    name = "crates_vendor",
    annotations = {
        "libgit2-sys": [crate.annotation(
            gen_build_script = False,
            # libgit2 comes from `bazel_dep(name = "libgit2")` in MODULE.bazel,
            # injected into this extension via `inject_repo`.
            deps = ["@libgit2"],
        )],
        "libz-sys": [crate.annotation(
            gen_build_script = False,
            # zlib comes from `bazel_dep(name = "zlib")` in MODULE.bazel.
            deps = ["@zlib"],
        )],
    },
    cargo_lockfile = "Cargo.Bazel.lock",
    generate_build_scripts = True,
    mode = "remote",
    packages = {
        "git2": crate.spec(
            default_features = False,
            version = "=0.20.0",
        ),
    },
    repository_name = "complex_sys",
    tags = ["manual"],
)
